# Production Environment Configuration
# =======================

# Node Environment
NODE_ENV=production
PORT=3000

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/changeaipay?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secure-jwt-secret-change-in-production
JWT_EXPIRY=7d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Nano RPC Nodes (comma-separated)
RPC_NODES=https://rpc.nano.node,https://nano.mynano.ninja,https://nanowallet.io/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=https://changeaipay.netlify.app,https://www.changeaipay.netlify.app

# WebSocket
WS_PORT=3001

# AI Service
AI_SERVICE_ENABLED=true
AI_MODEL=claude-3-sonnet

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production