MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/changeaipay
JWT_SECRET=replace-with-a-long-random-secret
RPC_URL=https://your-nano-rpc.example.com
RPC_API_KEY=
RPC_AUTH_TOKEN=
RPC_BASIC_USER=
RPC_BASIC_PASS=
RPC_TIMEOUT_MS=15000
RPC_CONFIRM_ATTEMPTS=8
